{
  "name": "wl-robot",
  "type": "module",
  "private": true,
  "packageManager": "npm@10.9.0",
  "engines": {
    "node": ">=23.0.0",
    "npm": ">=10.9.0"
  },
  "scripts": {
    "dev": "nuxt dev",
    "build": "cross-env ROBOT_ENABLED=true NODE_ENV=production nuxt build",
    "preview": "node scripts/preview.mjs",
    "deployment": "cross-env ROBOT_ENABLED=true NODE_ENV=production node .output/server/index.mjs",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "nuxt typecheck",
    "prepare": "nuxt prepare"
  },
  "dependencies": {
    "@wechatferry/agent": "^0.0.26",
    "@wechatferry/core": "^0.0.26",
    "cross-env": "^10.1.0",
    "nuxt": "^4.2.0"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.10.0",
    "@types/node": "^25.7.0",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.1.5"
  }
}
